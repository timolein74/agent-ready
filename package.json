{
  "name": "@asterpay/agent-ready",
  "version": "0.1.1",
  "description": "Make any API AI-agent discoverable — robots.txt, llms.txt, agent.json, MCP endpoint, scanner filter, CORS in one Fastify plugin",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "fastify-plugin": "^4.5.1",
    "zod": "^3.22.4"
  },
  "peerDependencies": {
    "fastify": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "fastify": {
      "optional": false
    }
  },
  "devDependencies": {
    "@types/node": "^20.11.16",
    "fastify": "^4.26.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "asterpay",
    "agent-ready",
    "ai-agents",
    "discovery",
    "llms.txt",
    "robots.txt",
    "mcp",
    "a2a",
    "fastify",
    "x402"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/timolein74/agent-ready"
  },
  "license": "MIT"
}
